// Copia a Secrets.xcconfig (gitignored) y completa con tus valores.
// cp Config/Secrets.xcconfig.example Config/Secrets.xcconfig
//
// Worker — elige UNA opción:
//   LAN (dev):     http://<IP-MAC>:8787   — iPhone y Mac en la misma WiFi (o hotspot del Mac)
//   Cloudflare:    https://puente-worker.<tu-cuenta>.workers.dev  — evita problemas de LAN
//                  (cd puente/backend/worker && npx wrangler login && npx wrangler deploy)
//
// Comandos Mac (Mail, etc.) siguen en LAN :8788 salvo que uses túnel aparte.

PUENTE_WORKER_BASE_URL = http:/$()/192.168.201.228:8787
PUENTE_COMMAND_BASE_URL = http:/$()/192.168.201.228:8788
PUENTE_CROSSING_WS_URL = ws:/$()/192.168.201.228:8765
PUENTE_WORKER_API_KEY =
PUENTE_COMMAND_TOKEN =
META_APP_ID = TU
CLIENT_TOKEN = TU_CLIENT_TOKEN
