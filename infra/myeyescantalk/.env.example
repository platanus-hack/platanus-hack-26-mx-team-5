# Copia este archivo a .env.local y pega tus claves reales.
# El app carga .env.local automáticamente.

# ── ElevenLabs (voz de Catalina) ──────────────────────────────────────────────
ELEVENLABS_API_KEY=sk_PEGA_AQUI_TU_API_KEY
# Opcional: fija un Voice ID exacto y se salta la búsqueda por nombre "Catalina".
# ELEVENLABS_VOICE_ID=

# ── Claude (el cerebro: razonamiento + visión) ────────────────────────────────
# Sin esto, el asistente usa un agente local de reglas (limitado).
# Con esto, razona, VE la pantalla y controla la Mac por voz.
# Crea la key en console.anthropic.com -> Settings -> API Keys (empieza con "sk-ant-").
ANTHROPIC_API_KEY=sk-ant-PEGA_AQUI_TU_KEY

# Opcional: modelo. Por defecto claude-opus-4-8 (máxima capacidad).
# Para menor latencia/costo: claude-sonnet-4-6.
# ANTHROPIC_MODEL=claude-opus-4-8
